# ============================================
# Python 项目 .gitignore
# ============================================

# --------------------------------------------
# 1. Python 编译缓存
# --------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# --------------------------------------------
# 2. 虚拟环境（所有 .venv 目录）
# --------------------------------------------
**/.venv/
venv/
ENV/
env/

# --------------------------------------------
# 3. HuggingFace 缓存（大模型文件，不跟踪）
# --------------------------------------------
hf_cache/
# 如果缓存内有具体模型文件夹，也可以选择性保留
# 但通常模型权重很大，建议不跟踪

# --------------------------------------------
# 4. 第三方库源代码（从其他仓库 clone，不上传）
# --------------------------------------------
external/
# 如需重建，可从原仓库 clone：
#   git clone https://github.com/amazon-science/chronos-forecasting.git external/chronos-forecasting
#   git clone https://github.com/google-research/timesfm.git external/timesfm
#   git clone https://github.com/DataDog/toto.git external/toto

# --------------------------------------------
# 4. 数据文件（选择性忽略）
# --------------------------------------------
data/raw/

# 处理后的数据（可重新生成）
data/processed/*.csv

# 预测结果（实验输出，不跟踪）
data/results/*.csv
data/results/*.png

# 但保留目录结构（使用 .gitkeep）
# data/raw/.gitkeep
# data/processed/.gitkeep
# data/results/.gitkeep

# --------------------------------------------
# 5. Jupyter Notebook 检查点
# --------------------------------------------
.ipynb_checkpoints
*.ipynb

# --------------------------------------------
# 6. 环境变量文件（包含敏感信息）
# --------------------------------------------
.env
.env.local
.env.*.local
secrets.yaml
secrets.json

# --------------------------------------------
# 7. IDE 和编辑器配置
# --------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.vs/
*.sublime-project
*.sublime-workspace

# --------------------------------------------
# 8. 操作系统文件
# --------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# --------------------------------------------
# 9. 日志文件
# --------------------------------------------
*.log
logs/
log/

# --------------------------------------------
# 10. 临时文件
# --------------------------------------------
tmp/
temp/
*.tmp
*.bak
*.backup

# --------------------------------------------
# 11. 测试相关（可选）
# --------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# --------------------------------------------
# 12. 其他（根据项目需要添加）
# --------------------------------------------
# 如果 external/ 里有大文件，可以针对性忽略
# external/**/build/
# external/**/dist/
